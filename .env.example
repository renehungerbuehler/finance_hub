# AI provider — set exactly ONE of the following.
# Priority order: Anthropic → OpenAI → Gemini → Ollama (local)

# Anthropic Claude (recommended — enables web search + PDF attachments)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT-4o (alternative)
# OPENAI_API_KEY=sk-...

# Google Gemini 2.0 Flash (alternative)
# GEMINI_API_KEY=AIza...

# Ollama — 100% local, no data leaves your machine
# Install Ollama from https://ollama.com, then: ollama pull llama3.2
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://host.docker.internal:11434   # default — points to Ollama on the host machine

# PostgreSQL connection string (used by api service)
DATABASE_URL=postgresql://finance:finance@db:5432/finance_hub

# API port (default: 3003)
API_PORT=3003

# On Mac mini, optionally bind-mount postgres data to host filesystem:
# Set in docker-compose.yml volumes section:
#   device: /Users/your_username/finance_hub_data
